<UserControl x:Class="DrinkReminder.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:DrinkReminder.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="380">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,8,16,14">
                <ui:CardExpander Header="饮水目标"
                                 Margin="0,0,0,8"
                                 Icon="Drink24">
                    <StackPanel Margin="20,8,20,14">
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="每日目标" VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding DailyGoalMl, StringFormat={}{0} ml}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <Slider Value="{Binding DailyGoalMl, Mode=TwoWay}"
                                Minimum="500"
                                Maximum="5000"
                                TickFrequency="100"
                                IsSnapToTickEnabled="True"
                                SmallChange="100"
                                LargeChange="500" />
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander Header="提醒设置"
                                 Margin="0,0,0,8"
                                 Icon="ClockAlarm24">
                    <StackPanel Margin="20,8,20,14">
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock DockPanel.Dock="Left" Text="启用定时提醒" VerticalAlignment="Center" />
                            <ui:ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding ReminderEnabled}" />
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="提醒间隔" VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding ReminderIntervalMinutes, StringFormat={}{0} 分钟}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <Slider Value="{Binding ReminderIntervalMinutes, Mode=TwoWay}"
                                Minimum="5"
                                Maximum="120"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                SmallChange="5"
                                LargeChange="15"
                                Margin="0,0,0,12"
                                IsEnabled="{Binding ReminderEnabled}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="开始时间"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding ReminderTimeOptions}"
                                          SelectedItem="{Binding ReminderStartTime, Mode=TwoWay}"
                                          ItemStringFormat="{}{0:hh\\:mm}"
                                          IsEnabled="{Binding ReminderEnabled}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="结束时间"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding ReminderTimeOptions}"
                                          SelectedItem="{Binding ReminderEndTime, Mode=TwoWay}"
                                          ItemStringFormat="{}{0:hh\\:mm}"
                                          IsEnabled="{Binding ReminderEnabled}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander Header="快捷记录按钮"
                                 Margin="0,0,0,8"
                                 Icon="Flash24">
                    <StackPanel Margin="20,8,20,14">
                        <ItemsControl ItemsSource="{Binding QuickRecordButtons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            Padding="10,4"
                                            Margin="2">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="{Binding StringFormat={}{0} ml}"
                                                       VerticalAlignment="Center" />
                                            <ui:Button DockPanel.Dock="Right"
                                                       Content="移除"
                                                       Appearance="Transparent"
                                                       Command="{Binding DataContext.RemoveQuickRecordButtonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}"
                                                       Padding="8,2"
                                                       Margin="8,0,0,0" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ui:Button Content="添加快捷按钮"
                                   Command="{Binding AddQuickRecordButtonCommand}"
                                   Appearance="Secondary"
                                   Margin="0,10,0,0" />
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander Header="应用行为"
                                 Margin="0,0,0,8"
                                 Icon="Window24">
                    <StackPanel Margin="20,8,20,14">
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="开机自启动" VerticalAlignment="Center" />
                            <ui:ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding AutoStart}" />
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="最小化到托盘" VerticalAlignment="Center" />
                            <ui:ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding MinimizeToTray}" />
                        </DockPanel>

                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="关闭时最小化到托盘" VerticalAlignment="Center" />
                            <ui:ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding CloseToTray}" />
                        </DockPanel>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander Header="外观"
                                 Margin="0,0,0,8"
                                 Icon="Color24">
                    <StackPanel Margin="20,8,20,14">
                        <ComboBox SelectedValue="{Binding SelectedTheme, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="跟随系统" Tag="system" />
                            <ComboBoxItem Content="浅色" Tag="light" />
                            <ComboBoxItem Content="深色" Tag="dark" />
                        </ComboBox>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander Header="数据"
                                 Margin="0,0,0,8"
                                 Icon="Database24">
                    <StackPanel Margin="20,8,20,14">
                        <ui:Button Content="导出数据"
                                   Command="{Binding ExportDataCommand}"
                                   Appearance="Secondary"
                                   Margin="0,0,0,8" />
                        <ui:Button Content="清除所有数据"
                                   Command="{Binding ClearAllDataCommand}"
                                   Appearance="Danger" />
                    </StackPanel>
                </ui:CardExpander>

                <ui:Button Content="保存设置"
                           Command="{Binding SaveSettingsCommand}"
                           Appearance="Primary"
                           Margin="0,8,0,8" />

                <ui:Button Content="恢复默认"
                           Command="{Binding ResetToDefaultCommand}"
                           Appearance="Transparent" />
            </StackPanel>
        </ScrollViewer>

        <Grid Visibility="{Binding ShowAddQuickButtonDialog, Converter={StaticResource BoolToVisibilityConverter}}"
              Panel.ZIndex="100">
            <Border Background="#7A000000" />
            <ui:Card Width="320"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Padding="16">
                <StackPanel>
                    <TextBlock Text="添加快捷按钮"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                    <TextBlock Text="按钮容量"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,4" />
                    <Slider Minimum="50"
                            Maximum="1000"
                            TickFrequency="50"
                            IsSnapToTickEnabled="True"
                            Value="{Binding NewQuickAmount, Mode=TwoWay}" />

                    <TextBlock Text="{Binding NewQuickAmount, StringFormat={}{0} ml}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,12" />

                    <UniformGrid Columns="2">
                        <ui:Button Content="取消"
                                   Command="{Binding CancelAddQuickButtonCommand}"
                                   Appearance="Secondary"
                                   Margin="0,0,4,0" />
                        <ui:Button Content="添加"
                                   Command="{Binding ConfirmAddQuickButtonCommand}"
                                   Appearance="Primary"
                                   Margin="4,0,0,0" />
                    </UniformGrid>
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>


