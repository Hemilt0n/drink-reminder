<UserControl x:Class="DrinkReminder.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="380">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,8">
            <!-- 饮水目标设置 -->
            <ui:CardExpander Header="💧 饮水目标"
                             Margin="0,0,0,8"
                             Icon="Drink24">
                <StackPanel Margin="24,8,24,16">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="每日目标" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DailyGoalMl, StringFormat={}{0} ml}"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Slider Value="{Binding DailyGoalMl}"
                            Minimum="500"
                            Maximum="5000"
                            TickFrequency="100"
                            IsSnapToTickEnabled="True"
                            SmallChange="100"
                            LargeChange="500" />
                </StackPanel>
            </ui:CardExpander>

            <!-- 提醒设置 -->
            <ui:CardExpander Header="⏰ 提醒设置"
                             Margin="0,0,0,8"
                             Icon="ClockAlarm24">
                <StackPanel Margin="24,8,24,16">
                    <!-- 启用提醒 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="启用定时提醒" VerticalAlignment="Center" />
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ReminderEnabled}" />
                    </Grid>

                    <!-- 提醒间隔 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="提醒间隔" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ReminderIntervalMinutes, StringFormat={}{0} 分钟}"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Slider Value="{Binding ReminderIntervalMinutes}"
                            Minimum="5"
                            Maximum="120"
                            TickFrequency="5"
                            IsSnapToTickEnabled="True"
                            SmallChange="5"
                            LargeChange="15"
                            Margin="0,0,0,12"
                            IsEnabled="{Binding ReminderEnabled}" />

                    <!-- 提醒时段 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="开始: "
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  SelectedItem="{Binding ReminderStartTime}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,8,0">
                            <ComboBoxItem Content="06:00" />
                            <ComboBoxItem Content="07:00" />
                            <ComboBoxItem Content="08:00" IsSelected="True" />
                            <ComboBoxItem Content="09:00" />
                            <ComboBoxItem Content="10:00" />
                        </ComboBox>

                        <TextBlock Grid.Column="2"
                                   Text="结束: "
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="3"
                                  SelectedItem="{Binding ReminderEndTime}"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="20:00" />
                            <ComboBoxItem Content="21:00" />
                            <ComboBoxItem Content="22:00" IsSelected="True" />
                            <ComboBoxItem Content="23:00" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </ui:CardExpander>

            <!-- 快捷记录按钮设置 -->
            <ui:CardExpander Header="⚡ 快捷记录按钮"
                             Margin="0,0,0,8"
                             Icon="Flash24">
                <StackPanel Margin="24,8,24,16">
                    <ItemsControl ItemsSource="{Binding QuickRecordButtons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlElevationBorderBrush}"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        Margin="2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding StringFormat={}{0} ml}" VerticalAlignment="Center" />
                                        <Button Content="✕"
                                                Command="{Binding DataContext.RemoveQuickRecordButtonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="4,0"
                                                Margin="4,0,0,0"
                                                FontSize="10" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ui:Button Content="+ 添加按钮"
                               Command="{Binding AddQuickRecordButtonCommand}"
                               Appearance="Transparent"
                               Margin="0,8,0,0" />
                </StackPanel>
            </ui:CardExpander>

            <!-- 窗口设置 -->
            <ui:CardExpander Header="🪟 窗口设置"
                             Margin="0,0,0,8"
                             Icon="Window24">
                <StackPanel Margin="24,8,24,16">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="开机自启动" VerticalAlignment="Center" />
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoStart}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="最小化到托盘" VerticalAlignment="Center" />
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MinimizeToTray}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="关闭时最小化到托盘" VerticalAlignment="Center" />
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CloseToTray}" />
                    </Grid>
                </StackPanel>
            </ui:CardExpander>

            <!-- 主题设置 -->
            <ui:CardExpander Header="🎨 主题设置"
                             Margin="0,0,0,8"
                             Icon="Color24">
                <StackPanel Margin="24,8,24,16">
                    <ComboBox SelectedItem="{Binding SelectedTheme}" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="跟随系统" Tag="system" />
                        <ComboBoxItem Content="浅色主题" Tag="light" />
                        <ComboBoxItem Content="深色主题" Tag="dark" />
                    </ComboBox>
                </StackPanel>
            </ui:CardExpander>

            <!-- 数据管理 -->
            <ui:CardExpander Header="📊 数据管理"
                             Margin="0,0,0,8"
                             Icon="Database24">
                <StackPanel Margin="24,8,24,16">
                    <ui:Button Content="导出数据"
                               Command="{Binding ExportDataCommand}"
                               Appearance="Secondary"
                               HorizontalAlignment="Stretch"
                               Margin="0,0,0,8" />

                    <ui:Button Content="清除所有数据"
                               Command="{Binding ClearAllDataCommand}"
                               Appearance="Danger"
                               HorizontalAlignment="Stretch" />
                </StackPanel>
            </ui:CardExpander>

            <!-- 保存按钮 -->
            <ui:Button Content="保存设置"
                       Command="{Binding SaveSettingsCommand}"
                       Appearance="Primary"
                       HorizontalAlignment="Stretch"
                       Margin="0,8,0,8" />

            <ui:Button Content="恢复默认设置"
                       Command="{Binding ResetToDefaultCommand}"
                       Appearance="Transparent"
                       HorizontalAlignment="Stretch" />

            <!-- 关于信息 -->
            <ui:Card Margin="0,16,0,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="喝水提醒小助手 v1.0.0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="帮助您养成规律饮水的好习惯"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>