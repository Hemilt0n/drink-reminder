<UserControl x:Class="DrinkReminder.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:converters="clr-namespace:DrinkReminder.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="380">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:SelectedDaysToAppearanceConverter x:Key="SelectedDaysToAppearanceConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 时间范围选择 -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="16,8,16,8">
            <ui:Button Content="7天"
                       Command="{Binding Show7DaysCommand}"
                       Appearance="Transparent"
                       Margin="0,0,8,0" />
            <ui:Button Content="14天"
                       Command="{Binding Show14DaysCommand}"
                       Appearance="Transparent"
                       Margin="0,0,8,0" />
            <ui:Button Content="30天"
                       Command="{Binding Show30DaysCommand}"
                       Appearance="Transparent" />
        </StackPanel>

        <!-- 统计图表 -->
        <ui:Card Grid.Row="1"
                 Margin="16,0,16,16"
                 Padding="16">
            <lvc:CartesianChart Series="{Binding ChartSeries}"
                                XAxes="{Binding XAxes}"
                                Height="200"
                                Background="Transparent" />
        </ui:Card>

        <!-- 历史列表 -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Margin="16,0,16,8">
            <ItemsControl ItemsSource="{Binding WeeklyStats}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="12">
                            <Button Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource {x:Static ui:ControlsDictionary.TransparentButtonStyleKey}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 日期 -->
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding FormattedDate}" FontSize="14" FontWeight="Medium" />
                                        <TextBlock Text="{Binding WeekDay}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <!-- 进度条 -->
                                    <ProgressBar Grid.Column="1"
                                                 Value="{Binding ProgressPercent}"
                                                 Maximum="100"
                                                 Height="6"
                                                 Margin="8,0"
                                                 VerticalAlignment="Center"
                                                 Foreground="#2196F3" />

                                    <!-- 饮水量 -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TotalMl, StringFormat={}{0} ml}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="8,0" />

                                    <!-- 状态图标 -->
                                    <ui:SymbolIcon Grid.Column="3"
                                                   Symbol="CheckmarkCircle24"
                                                   FontSize="16"
                                                   Foreground="#4CAF50"
                                                   Visibility="{Binding IsGoalMet, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 日期详情弹窗 -->
        <Grid Visibility="{Binding ShowDayDetail, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" Panel.ZIndex="100" />
            <ui:Card HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Width="320"
                     MaxHeight="400"
                     Panel.ZIndex="101">
                <StackPanel Margin="16">
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{Binding SelectedDayStats.FormattedDate, StringFormat={}{0} 饮水记录}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <ui:Button Content="✕"
                                   Command="{Binding CloseDayDetailCommand}"
                                   Appearance="Transparent"
                                   HorizontalAlignment="Right"
                                   Padding="4" />
                    </Grid>

                    <TextBlock Text="{Binding SelectedDayStats.TotalMl, StringFormat=总计: {0} ml}"
                               FontSize="14"
                               Margin="0,0,0,8" />

                    <TextBlock Text="{Binding SelectedDayStats.ProgressPercent, StringFormat=完成度: {0}%}"
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,12" />

                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedDayStats.Records}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FormattedTime}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Width="45" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding AmountMl, StringFormat={}{0} ml}"
                                                       FontSize="13"
                                                       Margin="4,0" />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Note}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>