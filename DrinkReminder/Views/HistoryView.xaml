<UserControl x:Class="DrinkReminder.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:converters="clr-namespace:DrinkReminder.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="380">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:SelectedDaysToAppearanceConverter x:Key="SelectedDaysToAppearanceConverter" />
    </UserControl.Resources>

    <Grid Margin="16,8,16,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10"
                Margin="0,0,0,10">
            <UniformGrid Columns="3">
                <ui:Button Content="7 天"
                           Command="{Binding Show7DaysCommand}"
                           Appearance="{Binding SelectedDays, Converter={StaticResource SelectedDaysToAppearanceConverter}, ConverterParameter=7}"
                           Margin="3,0" />
                <ui:Button Content="14 天"
                           Command="{Binding Show14DaysCommand}"
                           Appearance="{Binding SelectedDays, Converter={StaticResource SelectedDaysToAppearanceConverter}, ConverterParameter=14}"
                           Margin="3,0" />
                <ui:Button Content="30 天"
                           Command="{Binding Show30DaysCommand}"
                           Appearance="{Binding SelectedDays, Converter={StaticResource SelectedDaysToAppearanceConverter}, ConverterParameter=30}"
                           Margin="3,0" />
            </UniformGrid>
        </Border>

        <ui:Card Grid.Row="1" Margin="0,0,0,10" Padding="14">
            <StackPanel>
                <TextBlock Text="摄入趋势"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <lvc:CartesianChart Series="{Binding ChartSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    Height="210"
                                    Background="Transparent" />
            </StackPanel>
        </ui:Card>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding WeeklyStats}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Button Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       CommandParameter="{Binding}"
                                       Appearance="Transparent"
                                       Padding="10"
                                       Margin="0,0,0,6"
                                       HorizontalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding FormattedDate}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding WeekDay}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <ProgressBar Grid.Column="1"
                                                 Value="{Binding ProgressPercent, Mode=OneWay}"
                                                 Maximum="100"
                                                 Height="7"
                                                 Margin="10,0"
                                                 VerticalAlignment="Center"
                                                 Foreground="#FF2F80ED" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TotalMl, StringFormat={}{0} ml}"
                                               Margin="8,0"
                                               VerticalAlignment="Center" />

                                    <ui:SymbolIcon Grid.Column="3"
                                                   Symbol="CheckmarkCircle24"
                                                   FontSize="16"
                                                   Foreground="#FF43A047"
                                                   Visibility="{Binding IsGoalMet, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   VerticalAlignment="Center" />
                                </Grid>
                            </ui:Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Visibility="{Binding ShowDayDetail, Converter={StaticResource BoolToVisibilityConverter}}"
              Panel.ZIndex="100">
            <Border Background="#7A000000" />
            <ui:Card HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Width="330"
                     MaxHeight="420"
                     Padding="16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding SelectedDayStats.FormattedDate, StringFormat={}{0} 饮水详情}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <ui:Button DockPanel.Dock="Right"
                                   Content="关闭"
                                   Command="{Binding CloseDayDetailCommand}"
                                   Appearance="Transparent" />
                    </DockPanel>

                    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="总摄入" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                <TextBlock Text="{Binding SelectedDayStats.TotalMl, StringFormat={}{0} ml}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="完成度" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                <TextBlock Text="{Binding SelectedDayStats.ProgressPercent, StringFormat={}{0}%}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer MaxHeight="230" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedDayStats.Records}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="6,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="46" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FormattedTime}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding AmountMl, StringFormat={}{0} ml}"
                                                       FontWeight="SemiBold"
                                                       Margin="4,0" />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Note}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>

